#Load needed libraries
library(dplyr)
library(ggplot2)
library(tidyr)
library(fpp3)
# Read already filtered time series (tsibble)
# with Series ID CEU1000000001 (Mining and Logging)
mySeries <- readRDS("us_employment_filtered.rds")
head(mySeries)
str(mySeries)
summary(mySeries)
# Extracting number of rows for training set with 80/20 split
overall_count <- (nrow(mySeries))
training_row_count <- floor((nrow(mySeries) * 0.8))
train <- mySeries %>% slice(1:training_row_count)
# Mean method used
mean_employment_fit <- train %>%
model(
Mean = MEAN(Employed)
)
# View first impression of the fitted values
augment(mean_employment_fit)
augment(mean_employment_fit) %>%
autoplot(.fitted, colour="blue", linetype="dashed") +
autolayer(train, Employed) +
labs(y= "US Employment", title="Fitted and true values for monthly US employment rates (Mean method)")
augment(mean_employment_fit) %>%
ggplot(aes(x=Employed, y=.fitted)) +
geom_point() +
geom_abline(slope = 1, intercept = 0, linetype=2) +
labs(title = "Actual vs. Fitted (Mean Model)", x="Actual", y="Fitted")
mean_employment_fit %>% gg_tsresiduals()
augment(mean_employment_fit) %>%
features(.innov, box_pierce, lag=24)
# Calculate the mean of the residuals of the fitted model
residual_mean <- mean(
augment(mean_employment_fit)$.resid,
na.rm = TRUE)
residual_mean
# Make a forecast and save the result
fc_mean <- mean_employment_fit %>%
forecast(h = (nrow(mySeries) - nrow(train)))
# Create a time plot 'Actual vs. Forecast'
fc_mean %>%
autoplot(mySeries) +
labs(title="US Employment in Mining and Logging - Actual vs. Forecast (Mean Model)")
# Calculate the forecast accuracy metrics
fc_mean %>%
accuracy(mySeries)
# Residual diagnostics for checking homoscedasticity and normality
mean_employment_fit %>% gg_tsresiduals()
# Display prediction interval boundaries
fc_mean %>%
hilo()
# Extracting number of rows for training set with 80/20 split
overall_count <- (nrow(mySeries))
training_row_count <- floor((nrow(mySeries) * 0.8))
train <- mySeries %>% slice(1:training_row_count)
# Train the model with the seasonal naive drift method
naive_drift_employment_fit <- train %>% model (
SNaive_Drift = SNAIVE(Employed ~ drift())
)
# View the trained data
augment(naive_drift_employment_fit)
augment(naive_drift_employment_fit) %>%
autoplot(.fitted, colour="red", linetype="dashed") +
autolayer(train, Employed) +
labs(y= "US Employment", title="Fitted and true values for monthly US employment rates (Seasonal naive with drift method)")
augment(naive_drift_employment_fit) %>%
ggplot(aes(x=Employed, y=.fitted)) +
geom_point() +
geom_abline(slope = 1, intercept = 0, linetype=2) +
labs(title = "Actual vs. Fitted (Mean Model)", x="Actual", y="Fitted")
naive_drift_employment_fit %>% gg_tsresiduals()
augment(naive_drift_employment_fit) %>%
features(
.innov,
ljung_box,
lag = 24
)
augment(naive_drift_employment_fit) %>%
features(
.innov,
ljung_box(),
lag = 24
)
augment(naive_drift_employment_fit) %>%
features(
.innov,
ljung_box,
lag = 24
)
residual_mean_naive_drift <- mean(
augment(naive_drift_employment_fit)$.resid,
na.rm = TRUE)
residual_mean_naive_drift
augment(naive_drift_employment_fit) %>% forecast(h=overall_count - training_row_count)
naive_drift_employment_fit %>% forecast(h=overall_count - training_row_count)
fc_naive_drift <- naive_drift_employment_fit %>%
forecast(h=(overall_count - training_row_count))
fc_naive_drift %>% autoplot(mySeries)
fc_naive_drift <- naive_drift_employment_fit %>%
forecast(h=(overall_count - training_row_count))
fc_naive_drift %>%
autoplot(mySeries) +
labs(title="US Employment in Mining and Logging - Actual vs. Forecast (Seasonal naive with drift Model)")
fc_naive_drift %>% accuracy(mySeries)
naive_drift_employment_fit %>% gg_tsresiduals()
fc_naive_drift %>% hilo()
# 1. Load the required library
library(fpp3)
# 2. Briefly inspect the dataset
us_employment
# 3. Filter for your specific Series_ID
mySeries <- us_employment |>
filter(Series_ID == "CEU1000000001")
# 4. Inspect the filtered result
View(mySeries)
autoplot(mySeries)
# 5. Remove leading NAs
# The employment data values are stored in the 'Employed' column.
mySeries <- mySeries |>
drop_na(Employed)
# 6. Save the resulting time series to disk
saveRDS(mySeries, "mySeries.rds")
# 1. Extract the Training Set
training_set_size <- floor(nrow(mySeries) * 0.8)
# 2. 80%
train <- mySeries %>%
slice(1:training_set_size)
test_set_size <- nrow(mySeries) - training_set_size
print(paste("Length of test set (h):", test_set_size))
# Train SNAIVE
fit_advanced <- train |>
model(
snaive = SNAIVE(Employed)
)
# 1. Load the required library
library(fpp3)
# 2. Briefly inspect the dataset
us_employment
# 3. Filter for your specific Series_ID
mySeries <- us_employment |>
filter(Series_ID == "CEU1000000001")
# 4. Inspect the filtered result
View(mySeries)
autoplot(mySeries)
# 5. Remove leading NAs
# The employment data values are stored in the 'Employed' column.
mySeries <- mySeries |>
drop_na(Employed)
# 6. Save the resulting time series to disk
saveRDS(mySeries, "mySeries.rds")
# 1. Extract the Training Set
training_set_size <- floor(nrow(mySeries) * 0.8)
# 2. 80%
train <- mySeries %>%
slice(1:training_set_size)
test_set_size <- nrow(mySeries) - training_set_size
print(paste("Length of test set (h):", test_set_size))
# Train SNAIVE
fit_advanced <- train |>
model(
snaive = SNAIVE(Employed)
)
# 3a. Time plot 'Actual vs. Fitted'
augment(fit_advanced) |>
autoplot(Employed) +
autolayer(augment(fit_advanced), .fitted, colour = "red") +
labs(title = "SNAIVE: Actual vs. Fitted",
y = "Employment",
x = "Time")
# 3b. Scatter Plot
augment(fit_advanced) |>
ggplot(aes(x = Employed, y = .fitted)) +
geom_point() +
geom_abline(slope = 1, intercept = 0, linetype = 2) +
labs(title = "SNAIVE: Scatter Plot of Actual vs. Fitted",
x = "Actual Values",
y = "Fitted Values")
# 3c. Residual diagnostics
fit_advanced |> gg_tsresiduals()
# 3d. Ljung-Box test
augment(fit_advanced) |>
features(.innov, ljung_box, lag = 24, dof = 0)
# Calculate the residual mean
mean(augment(fit_advanced)$.innov, na.rm = TRUE)
# 4a. Make the forecast
fc_advanced <- fit_advanced |>
forecast(h = test_set_size)
# 4b. Plot the forecasts against the actual data
fc_advanced |>
autoplot(mySeries, level = NULL) +
labs(title = "Forecast: SNAIVE vs Actual",
y = "Employment",
x = "Time")
# 4c. Calculate accuracy
fc_advanced |> accuracy(mySeries)
# Train Seasonal Naive with Drift
fit_model2 <- train |>
model(
snaive_drift = SNAIVE(Employed ~ drift())
)
# 3a. Time plot 'Actual vs. Fitted'
augment(fit_model2) |>
autoplot(Employed) +
autolayer(augment(fit_model2), .fitted, colour = "blue") +
labs(title = "SNAIVE w/ Drift: Actual vs. Fitted",
y = "Employment",
x = "Time")
# 3b. Scatter Plot
augment(fit_model2) |>
ggplot(aes(x = Employed, y = .fitted)) +
geom_point() +
geom_abline(slope = 1, intercept = 0, linetype = 2) +
labs(title = "SNAIVE w/ Drift: Scatter Plot",
x = "Actual Values",
y = "Fitted Values")
# 3c. Residual diagnostics
fit_model2 |> gg_tsresiduals()
# 3d. Ljung-Box test & Residual Mean
augment(fit_model2) |>
features(.innov, ljung_box, lag = 24, dof = 0)
mean(augment(fit_model2)$.innov, na.rm = TRUE)
# 4a. Make the forecast
fc_model2 <- fit_model2 |>
forecast(h = test_set_size)
# 4b. Plot the forecasts against the actual data
fc_model2 |>
autoplot(mySeries, level = NULL) +
labs(title = "Forecast: SNAIVE w/ Drift vs Actual",
y = "Employment",
x = "Time")
# 4c. Calculate forecast accuracy metrics
fc_model2 |> accuracy(mySeries)
